{
  "name": "portfolio-admin-functions",
  "description": "Cloud Functions: fan out FCM pushes when /contacts/{id} is created.",
  "engines": { "node": "20" },
  "main": "index.js",
  "private": true,
  "scripts": {
    "serve":  "firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions:notifyAdminsOnNewContact",
    "logs":   "firebase functions:log"
  },
  "dependencies": {
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^6.0.1"
  }
}
